<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="tabarag"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <DpiAware Value="True"/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="atflatcontrols_package"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="tabarag.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="src\views\umainform.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="MainForm"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="uMainForm"/>
      </Unit>
      <Unit>
        <Filename Value="src\utils\ujsonhelper.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uJsonHelper"/>
      </Unit>
      <Unit>
        <Filename Value="src\models\ufaqmodel.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uFaqModel"/>
      </Unit>
      <Unit>
        <Filename Value="src\models\uchatmodel.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uChatModel"/>
      </Unit>
      <Unit>
        <Filename Value="src\database\udbconnection.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uDBConnection"/>
      </Unit>
      <Unit>
        <Filename Value="src\database\udbtables.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uDBTables"/>
      </Unit>
      <Unit>
        <Filename Value="src\services\uembeddingservice.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uEmbeddingService"/>
      </Unit>
      <Unit>
        <Filename Value="src\services\ufaqservice.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uFaqService"/>
      </Unit>
      <Unit>
        <Filename Value="src\services\uchatservice.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uChatService"/>
      </Unit>
      <Unit>
        <Filename Value="src\views\ufaqform.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="FaqForm"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="uFaqForm"/>
      </Unit>
      <Unit>
        <Filename Value="src\services\uchatllmservice.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="uChatLLMService"/>
      </Unit>
      <Unit>
        <Filename Value="src\views\uservicemanagerform.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="ServiceManagerForm"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="uServiceManagerForm"/>
      </Unit>
      <Unit>
        <Filename Value="src\views\ufaqlistform.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="FaqListForm"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="uFaqListForm"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="Bin\tabarag"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="src\views;src\utils;src\models;src\database;src\services"/>
      <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <GenerateDebugInfo Value="False"/>
        <RunWithoutDebug Value="True"/>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
  </CompilerOptions>
  <Debugging>
    <Exceptions>
      <Item>
        <Name Value="EAbort"/>
      </Item>
      <Item>
        <Name Value="ECodetoolError"/>
      </Item>
      <Item>
        <Name Value="EFOpenError"/>
      </Item>
    </Exceptions>
  </Debugging>
</CONFIG>
